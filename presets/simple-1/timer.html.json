{
  "Author": "WolfwithSword",
  "Url": "https://docs.subathonmanager.app/latest/widgets/presets/themesets/simple-1/#timer",
  "Width": 460,
  "Height": 110,
  "Vars": {
    "finishSound": {
      "Name": "finishSound",
      "Type": "SoundFile",
      "Description": "Sound to play when timer hits 00:00",
      "Value": "./done.mp3",
      "Options": null
    },
    "playSoundOnFinish": {
      "Name": "playSoundOnFinish",
      "Type": "Boolean",
      "Description": "Play sound on finish?",
      "Value": false,
      "Options": null
    },
    "soundVolume": {
      "Name": "soundVolume",
      "Type": "Percent",
      "Description": "",
      "Value": 50,
      "Options": null
    },
    "GoogleFonts" : {
      "type": "GoogleFont",
      "description": "Additional google fonts to load to use in CSS Variables. Comma separated.",
      "value": "Titan One,Poppins"
    },
    "CdnFonts" : {
      "type": "CdnFont",
      "description": "Additional cdn fonts to load to use in CSS Variables. Comma separated.",
      "value": "bright-orchid,milker,beachday"
    }
  }
}