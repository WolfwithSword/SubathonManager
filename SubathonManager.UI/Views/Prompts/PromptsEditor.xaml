<UserControl x:Class="SubathonManager.UI.Views.Prompts.PromptsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="8" Margin="16 16 8 16"
                BorderThickness="1" BorderBrush="#333" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="SetNameTextBox"
                                FontWeight="Bold" FontSize="18"
                                PlaceholderText="Set name…"
                                ClearButtonEnabled="False"
                                Height="38"
                                BorderThickness="0"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                Margin="2"
                                LostFocus="SetNameTextBox_LostFocus"/>
                    <ui:Button Grid.Column="1" x:Name="RunOrCancelBtn" Width="36" Height="36" Padding="2"
                               ToolTip="Run a random prompt now" Click="RunOrCancel_Click"
                               Margin="0 0 4 0">
                        <ui:SymbolIcon x:Name="RunOrCancelIcon" Symbol="Play24" Width="20" Height="20"/>
                    </ui:Button>
                    <ui:Button Grid.Column="2" Width="36" Height="36" Padding="2"
                               ToolTip="Add New Prompt" Click="AddPrompt_Click">
                        <ui:SymbolIcon Symbol="Add24" Width="20" Height="20"/>
                    </ui:Button>
                </Grid>

                <Border Grid.Row="1" BorderBrush="#444" BorderThickness="0 0 0 1" Margin="0 4 0 2">
                    <Grid Margin="4 0 8 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="66"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="On" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Prompt Text" FontSize="11" Foreground="Gray" Margin="6 0 -24 0"/>
                        <TextBlock Grid.Column="2" Text="Type" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Value" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Dur" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="Qty" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" x:Name="PromptsScroller" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PromptsStack" Orientation="Vertical" Margin="0 2 0 0"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20 16 16 56">

                    <TextBlock Text="Prompts Editor" FontSize="20" FontWeight="Bold" Margin="0 0 0 10"/>
                    <Grid Margin="0 0 0 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="SetSelectorBox" Height="36"
                                  SelectionChanged="SetSelectorBox_SelectionChanged"/>
                        <ui:Button Grid.Column="1" Width="34" Height="34" Padding="2" Margin="4 0 0 0"
                                   ToolTip="New prompt set" Click="NewSet_Click">
                            <ui:SymbolIcon Symbol="Add24" Width="18" Height="18"/>
                        </ui:Button>
                        <ui:Button Grid.Column="2" x:Name="DeleteSetBtn" Width="34" Height="34" Padding="2" Margin="4 0 0 0"
                                   ToolTip="Delete this prompt set" Click="DeleteSet_Click"
                                   Foreground="Red">
                            <ui:SymbolIcon Symbol="Delete24" Width="18" Height="18"/>
                        </ui:Button>
                        <Separator Grid.Column="3" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="8 4"/>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Enabled" VerticalAlignment="Center" Margin="0 0 6 0" FontSize="12"/>
                            <CheckBox x:Name="SetEnabledCheck" VerticalAlignment="Center"
                                      Checked="SetEnabled_Changed" Unchecked="SetEnabled_Changed"/>
                        </StackPanel>
                    </Grid>

                    <Border Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6" Margin="0 0 0 12">
                        <StackPanel>
                            <TextBlock Text="Timing" FontSize="14" FontWeight="SemiBold" Margin="0 0 0 8"/>
                            <Grid Margin="0 0 0 4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Interval:" VerticalAlignment="Center" FontSize="12"/>
                                <ui:TextBox x:Name="SetIntervalBox" Grid.Column="2" Height="34" ClearButtonEnabled="False"
                                            PreviewTextInput="NumberOnly_PreviewTextInput"
                                            ToolTip="How often (minutes) the set tries to fire a prompt"/>
                                <TextBlock Grid.Column="3" Text="m" VerticalAlignment="Center" Margin="6 0 0 0" Foreground="Gray"/>
                            </Grid>

                            <Grid Margin="0 0 0 4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Offset:" VerticalAlignment="Center" FontSize="12"/>
                                <ui:TextBox x:Name="SetOffsetBox" Grid.Column="2" Height="34" ClearButtonEnabled="False"
                                            PreviewTextInput="NumberOnly_PreviewTextInput"
                                            ToolTip="Max random amount of time +- from the interval to add variety"/>
                                <TextBlock Grid.Column="3" Text="m" VerticalAlignment="Center" Margin="6 0 0 0" Foreground="Gray"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cooldown:" VerticalAlignment="Center" FontSize="12"/>
                                <ui:TextBox x:Name="SetCooldownBox" Grid.Column="2" Height="34" ClearButtonEnabled="False"
                                            PreviewTextInput="NumberOnly_PreviewTextInput"
                                            ToolTip="Minutes to wait after a prompt ends before the next one can start."/>
                                <TextBlock Grid.Column="3" Text="m" VerticalAlignment="Center" Margin="6 0 0 0" Foreground="Gray"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PromptDetailBorder"
                            Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                            Margin="0 0 0 12" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Selected Prompt" FontSize="14" FontWeight="SemiBold" Margin="0 0 0 8"/>

                            <Border x:Name="RunningLockText"
                                    Visibility="Collapsed"
                                    Background="#22FF8800"
                                    BorderBrush="#66FF8800"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8 6"
                                    Margin="0 0 0 8">
                                <TextBlock Text="⏵ This prompt is currently running - editing is locked."
                                           FontSize="12"
                                           Foreground="Orange"/>
                            </Border>

                            <TextBlock Text="Text:" FontSize="12" Margin="2 0 0 3"/>
                            <ui:TextBox x:Name="PromptTextBox" PlaceholderText="What should viewers do…"
                                        ClearButtonEnabled="False" Height="36" Margin="0 0 0 8"/>

                            <Grid Margin="0 0 0 8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Type:" FontSize="12" Margin="2 0 0 3"/>
                                    <ComboBox x:Name="PromptTypeBox" Height="36" SelectionChanged="PromptType_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="How?" FontSize="12" Margin="2 0 0 3"/>
                                    <ComboBox x:Name="PromptSubTypeBox" Height="36"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="EventTypePanel" Visibility="Collapsed" Margin="0 0 0 8">
                                <TextBlock Text="Event:" FontSize="12" Margin="2 0 0 3"/>
                                <Grid Margin="0 0 0 2">
                                    <Button x:Name="EventTypePickerBtn"
                                            Height="36"
                                            MinWidth = "130"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="8 0 6 0"
                                            Click="EventTypePickerBtn_Click"
                                            Background="{DynamicResource ComboBoxBackground}"
                                            BorderBrush="{DynamicResource ComboBoxBorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="EventTypePickerLabel"
                                                       Text="- select -"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Path Grid.Column="1"
                                                  Data="M 0 0 L 4 4 L 8 0"
                                                  Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                                                  StrokeThickness="1.5"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Popup x:Name="EventTypePopup"
                                           PlacementTarget="{Binding ElementName=EventTypePickerBtn}"
                                           Placement="Bottom"
                                           StaysOpen="True"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade">
                                        <Border x:Name="EventTypePopupBorder"
                                                Background="{DynamicResource ApplicationBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                MouseEnter="EventTypePopupBorder_MouseEnter"
                                                MouseLeave="EventTypePopupBorder_MouseLeave">
                                            <StackPanel Orientation="Horizontal">
                                                <ListBox x:Name="SourceListBox"
                                                         Width="150"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                                                <Border x:Name="EventListPanel"
                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                        BorderThickness="1 0 0 0"
                                                        Visibility="Collapsed"
                                                        MouseEnter="EventTypePopupBorder_MouseEnter">
                                                    <ListBox x:Name="EventListBox"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             MinWidth="150"
                                                             MaxHeight="300"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             MouseLeftButtonUp="EventListBox_MouseLeftButtonUp"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="TierFilterPanel" Visibility="Collapsed" Margin="0 0 0 8">
                                <TextBlock Text="Tier:" FontSize="12" Margin="2 0 0 3"/>
                                <ComboBox x:Name="PromptTierBox" Height="36"/>
                            </StackPanel>

                            <Grid Margin="0 0 0 8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="ValueLabel" Text="Target Value:" FontSize="12" Margin="2 0 0 3"/>
                                    <ui:TextBox x:Name="PromptValueBox" Height="36" ClearButtonEnabled="False"
                                                PreviewTextInput="NumberOnly_PreviewTextInput"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Duration (min):" FontSize="12" Margin="2 0 0 3"/>
                                    <ui:TextBox x:Name="PromptDurationBox" Height="36" ClearButtonEnabled="False"
                                                PreviewTextInput="NumberOnly_PreviewTextInput"
                                                ToolTip="How many minutes viewers have to complete this prompt"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0 0 0 8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Quantity:" FontSize="12" Margin="2 0 0 3"/>
                                    <ui:TextBox x:Name="PromptQuantityBox" Height="36" ClearButtonEnabled="False"
                                                PreviewTextInput="NumberOnly_PreviewTextInput"
                                                ToolTip="How many times this prompt can succeed. Ignored if Infinite is on."/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0 0 0 6">
                                    <CheckBox x:Name="PromptInfiniteCheck" Content="Infinite (no limit)"
                                              Checked="PromptInfinite_Changed" Unchecked="PromptInfinite_Changed"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="StatusText" Foreground="Gray" FontSize="12" Margin="0 0 0 6"/>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="SaveButtonBorder"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    CornerRadius="6"
                    BorderThickness="2"
                    BorderBrush="Transparent"
                    Margin="6 10 14 10">
                <ui:Button x:Name="SaveBtn" Content="Save Changes" Click="Save_Click" Width="140" Height="38"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
