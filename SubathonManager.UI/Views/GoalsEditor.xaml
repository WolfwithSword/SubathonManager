<UserControl x:Class="SubathonManager.UI.Views.GoalsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Focusable="True" MouseDown="Grid_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="8" Margin="16 16 8 16"
                BorderThickness="1" BorderBrush="#333" CornerRadius="8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="GoalSetNameBox" Width="640" 
                                Height="38"
                                IsTabStop="False"
                                BorderThickness="0" FontSize="18"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                PlaceholderText="Set name…" FontWeight="Bold" Margin="2"
                                HorizontalAlignment="Left"
                                ClearButtonEnabled="False" LostFocus="GoalSetNameBox_LostFocus"/>
                    <ui:Button Grid.Column="1" Width="36" Height="36" Padding="2"
                               ToolTip="New Goal" Click="AddGoal_Click">
                        <ui:SymbolIcon Symbol="Add24" Width="20" Height="20"/>
                    </ui:Button>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="8 12 8 2">
                    <TextBlock Text="Goal" Width="522"/>
                    <TextBlock Text="Points" Width="60" Margin="8 0 0 0"/>
                </StackPanel>
                <ScrollViewer x:Name="GoalsEditorScroller" MaxHeight="600" Height="600"
                              VerticalScrollBarVisibility="Visible">
                    <StackPanel x:Name="GoalsStack" Orientation="Vertical" Margin="0 2 0 0"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20 16 16 56" VerticalAlignment="Top">

                    <TextBlock Text="Goals Editor" FontSize="20" FontWeight="Bold"/>

                    <Grid Margin="0 10 0 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="GoalSetSelectorBox" Height="36"
                                  SelectionChanged="GoalSetSelectorBox_SelectionChanged"/>
                        <ui:Button Grid.Column="1" Width="34" Height="34" Padding="2" Margin="4 0 0 0"
                                   ToolTip="New goal set" Click="NewGoalSet_Click">
                            <ui:SymbolIcon Symbol="Add24" Width="18" Height="18"/>
                        </ui:Button>
                        <ui:Button Grid.Column="2" x:Name="DeleteGoalSetBtn" Width="34" Height="34" Padding="2" Margin="4 0 0 0"
                                   ToolTip="Delete this goal set" Click="DeleteGoalSet_Click"
                                   Foreground="Red">
                            <ui:SymbolIcon Symbol="Delete24" Width="18" Height="18"/>
                        </ui:Button>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                        <ComboBox x:Name="GoalSetType" Width="120" Height="36" VerticalAlignment="Center"
                                  ToolTip="Points will be based off points. Money is based on total donations."
                                  SelectionChanged="GoalSetType_SelectionChanged"/>
                    </StackPanel>

                    <Grid Margin="0 16 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MoneyValue" HorizontalAlignment="Left"
                                   Text="" VerticalAlignment="Center" FontSize="24" Margin="16 2 8 6"/>
                        <TextBlock Grid.Column="1" x:Name="PointsValue" HorizontalAlignment="Right"
                                   Text="" VerticalAlignment="Center" FontSize="24" Margin="0 2 16 6"/>
                    </Grid>

                    <Separator Margin="0 10 0 10"/>
                    <TextBlock x:Name="StatusText" Foreground="Gray" FontSize="12" Margin="0 10 0 0"/>
                </StackPanel>
            </ScrollViewer>
            <Border x:Name="SaveButtonBorder"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    CornerRadius="6"
                    BorderThickness="2"
                    BorderBrush="Transparent" 
                    Margin="6 10 14 10">
                <ui:Button x:Name="SaveGoalsBtn" Content="Save Changes" Click="SaveGoals_Click" Width="140" Height="38"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
