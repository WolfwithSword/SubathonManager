<ui:FluentWindow x:Class="SubathonManager.UI.Views.ExportOverlayDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Export Overlay"
                 Width="560" Height="580"
                 MinWidth="560" MinHeight="580"
                 MaxWidth="560" MaxHeight="580"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 Background="{DynamicResource AppGeneralBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Name -->
            <RowDefinition Height="Auto"/>  <!-- files label -->
            <RowDefinition Height="*"/>     <!-- file tree -->
            <RowDefinition Height="Auto"/>  <!-- warning msg -->
            <RowDefinition Height="Auto"/>  <!-- btns -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <ui:TextBlock FontTypography="BodyStrong" Text="Export Name" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="ExportNameBox" PlaceholderText="Overlay name..." />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Vertical">
            <DockPanel  Margin="0,0,0,6" LastChildFill="False">
                <ui:TextBlock DockPanel.Dock="Left"
                              FontTypography="BodyStrong"
                              Text="Files to be included"
                              VerticalAlignment="Center"/>
                <CheckBox x:Name="SelectAllBox"
                          DockPanel.Dock="Right"
                          Content="Select all"
                          IsChecked="True"
                          VerticalAlignment="Center"
                          Checked="SelectAllBox_Checked"
                          Unchecked="SelectAllBox_Unchecked"/>
            </DockPanel>
            
            
            <TextBlock TextWrapping="Wrap"
                       MaxWidth="440"
                       FontSize="12"
                       Text="Please verify the files to be included in the export. Not all selected may be in use." />
        </StackPanel>
        
        <!-- file tree -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource UiBrushBorder}"
                BorderThickness="2" CornerRadius="4"
                Margin="0,0,0,10">
            
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="4">
                <TreeView x:Name="FileTree" Background="Transparent"
                          BorderThickness="0"
                          Padding="2"/>
            </ScrollViewer>
        </Border>

        <!-- Warning -->
        <Border Grid.Row="3"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCautionBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24"
                               Foreground="{DynamicResource SystemFillColorCautionBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Top"/>
                <TextBlock TextWrapping="Wrap"
                           MaxWidth="440"
                           FontSize="12"
                           Text="This export may not include all required files. Files referenced by hardcoded paths inside widget HTML/JS/CSS sources, or assets outside each widget's folder, may not be bundled automatically." />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <ui:Button DockPanel.Dock="Right"
                       x:Name="ConfirmButton" Content="Export…" Appearance="Primary"
                       Width="110"
                       Margin="8,0,0,0"
                       Click="ConfirmButton_Click"/>
            <ui:Button DockPanel.Dock="Right"
                       x:Name="CancelButton"
                       Content="Cancel" Appearance="Secondary"
                       Width="90"
                       Click="CancelButton_Click"/>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
