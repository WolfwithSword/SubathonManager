<UserControl x:Class="SubathonManager.UI.Views.CssColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:uiUtils="clr-namespace:SubathonManager.UI.UiUtils"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="200">
    <UserControl.Resources>
        <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFCCCCCC">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4"/>
                                <RectangleGeometry Rect="4,4,4,4"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>      
        <Style x:Key="SliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="White" BorderBrush="#AA000000" BorderThickness="1.5" CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="ColorSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="SmallChange" Value="0.01"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid x:Name="SliderGrid">
                            <Rectangle Fill="Transparent"
                                       MouseDown="ColorSlider_MouseDown"
                                       MouseMove="ColorSlider_MouseMove"
                                       MouseUp="ColorSlider_MouseUp"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="32">
            <Button x:Name="SwatchButton" Width="32" Height="32" Padding="0"
                    Click="SwatchButton_Click" ToolTip="Pick colour" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Grid>
                                <Border Background="{StaticResource CheckerBrush}" CornerRadius="3"/>
                                <Border x:Name="SwatchFill" CornerRadius="3"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchFill" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <ui:TextBox x:Name="CssValueBox"
                     Width="112"
                     Height="32"
                     Margin="4,0,0,0"
                     Padding="4,0"
                     VerticalContentAlignment="Center"
                     IsReadOnly="False"
                     Focusable="True"
                     Cursor="Arrow"
                     TextChanged="CssValueBox_TextChanged"
                     LostFocus="CssValueBox_LostFocus"/>
        </StackPanel>

        <Popup x:Name="PickerPopup"
               PlacementTarget="{Binding ElementName=SwatchButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Width="240">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Direction="270"/>
                </Border.Effect>
                <StackPanel Orientation="Vertical">

                    <Grid Width="216" Height="160" Margin="0,0,0,10" Cursor="Cross">
                        <Border x:Name="SvCanvas" CornerRadius="4" ClipToBounds="True" Width="216" Height="160">
                            <Grid>
                                <Border x:Name="HueBackground" CornerRadius="4"/>
                                <Border CornerRadius="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                
                                <Border CornerRadius="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="Black" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <Canvas x:Name="SvThumbCanvas" Width="216" Height="160"
                                MouseDown="SvCanvas_MouseDown"
                                MouseMove="SvCanvas_MouseMove"
                                MouseUp="SvCanvas_MouseUp"
                                Background="Transparent">
                            <Ellipse x:Name="SvThumb"
                                     Width="12" Height="12"
                                     Stroke="White" StrokeThickness="2"
                                     Fill="Transparent"
                                     Canvas.Left="0" Canvas.Top="0">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.5"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Grid>

                    <Grid Height="22" Margin="0,0,0,8">
                        <Border CornerRadius="4" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF0000" Offset="0"/>
                                    <GradientStop Color="#FFFF00" Offset="0.167"/>
                                    <GradientStop Color="#00FF00" Offset="0.333"/>
                                    <GradientStop Color="#00FFFF" Offset="0.5"/>
                                    <GradientStop Color="#0000FF" Offset="0.667"/>
                                    <GradientStop Color="#FF00FF" Offset="0.833"/>
                                    <GradientStop Color="#FF0000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <uiUtils:ClickDragSlider x:Name="HueSlider"
                                               Style="{StaticResource ColorSliderStyle}"
                                               Maximum="360" Minimum="0" SmallChange="1"
                                               ValueChanged="HueSlider_ValueChanged"
                                               Background="Transparent"/>
                    </Grid>
                    <Grid Height="22" Margin="0,0,0,12">
                        <Border CornerRadius="4" ClipToBounds="True">
                            <Grid>
                                <Border Background="{StaticResource CheckerBrush}"/>
                                <Border x:Name="AlphaGradientBorder" CornerRadius="4"/>
                            </Grid>
                        </Border>
                        <uiUtils:ClickDragSlider x:Name="AlphaSlider"
                                               Style="{StaticResource ColorSliderStyle}"
                                               ValueChanged="AlphaSlider_ValueChanged"
                                               Background="Transparent"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" Margin="0,0,10,0" ClipToBounds="True">
                            <Grid>
                                <Border Background="{StaticResource CheckerBrush}" CornerRadius="2"/>
                                <Border x:Name="PreviewSwatch" CornerRadius="2"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                            <ui:TextBlock Text="Hex" FontSize="10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,3"/>
                            <ui:TextBox x:Name="HexInputBox"
                                     Height="32"
                                     Padding="4,0"
                                     VerticalContentAlignment="Center"
                                     MaxLength="9"
                                     TextChanged="HexInputBox_TextChanged"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Close" Margin="0,10,0,0"
                            HorizontalAlignment="Stretch"
                            Click="ApplyButton_Click"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
