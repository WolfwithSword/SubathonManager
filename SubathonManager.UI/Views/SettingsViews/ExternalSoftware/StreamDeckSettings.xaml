<views:SettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.ExternalSoftware.StreamDeckSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:SubathonManager.UI.Views"
             mc:Ignorable="d">
    <StackPanel Orientation="Vertical" Margin="0,0,0,6">
        <StackPanel Orientation="Horizontal" Margin="0,4,0,6">
            <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Content="Setup" Click="OpenStreamDeckSetup_Click"
                       Width="60" Padding="2" Height="34" Margin="0,0,6,0"/>
            <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Content="Download Stream Deck Plugin" Click="DownloadPlugin_Click"
                       Width="240" Padding="2" Height="34" Cursor="Hand" Margin="6,0,0,0"/>
            <TextBlock Text="Status:" VerticalAlignment="Center" Margin="14,0,4,0" FontSize="12"/>
            <TextBlock x:Name="StreamDeckStatusText" Text="Disconnected"
                       VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>
        <TextBlock x:Name="StreamDeckInfoText" TextWrapping="Wrap" FontSize="12" Margin="2,0,0,4"
                   Text="Install the plugin, then add the 'Subathon Command' action to any key in the Stream Deck app."/>
    </StackPanel>
</views:SettingsControl>
