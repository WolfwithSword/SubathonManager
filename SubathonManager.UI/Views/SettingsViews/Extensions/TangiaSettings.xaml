<views:SettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.Extensions.TangiaSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:validation="clr-namespace:SubathonManager.UI.Validation"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:SubathonManager.UI.Views"
             mc:Ignorable="d">
    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
            <ui:PasswordBox x:Name="EventKeyBox"
                            Width="200" Height="35"
                            PlaceholderText="Event Key"
                            IsEnabled="False"
                            views:SettingsProperties.ExcludeFromUnsaved="True"
                            Margin="0,0,8,0"/>
            <ui:Button x:Name="GetKeyBtn"
                       Content="Get Key"
                       Width="80" Height="35"
                       Margin="0,0,8,0"
                       Click="GetKey_Click"/>
            <ui:Button x:Name="DisconnectBtn"
                       Content="Disconnect"
                       Width="100" Height="35"
                       Margin="0,0,8,0"
                       Visibility="Collapsed"
                       Click="Disconnect_Click"/>
            <TextBlock x:Name="StatusText"
                       Text="Disconnected"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Margin="8,0,0,0"/>
        </StackPanel>
        <StackPanel Margin="10,5,0,5">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Tokens:" Width="80" VerticalAlignment="Center" ToolTip="Covers both Bits and Tangia Coins"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="12" x:Name="TokensSecondsBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds/100" Width="110" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="TokensPointsBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Points/100" ToolTip="Rounded down" Width="140" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:TextBox Width="80" Text="100"
                                PlaceholderText="100"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ClearButtonEnabled="False"
                                Height="34"
                                FontSize="12"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsNumberOnly="True"
                                x:Name="SimulateTangiaAmt"/>
                    <ui:Button Icon="Add24" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test"
                               Click="TestTangia_Click"
                               Width="60" Padding="2"
                               Height="34"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </StackPanel>
</views:SettingsControl>
