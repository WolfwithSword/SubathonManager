<settingsViews:SettingsGroupControl x:Class="SubathonManager.UI.Views.SettingsViews.ExternalSettings"
                                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                                    xmlns:views="clr-namespace:SubathonManager.UI.Views"
                                    xmlns:settingsViews="clr-namespace:SubathonManager.UI.Views.SettingsViews"
                                    mc:Ignorable="d"
                                    d:DesignHeight="300" d:DesignWidth="300">
    
    <Expander Header="External Services" IsExpanded="False">
        <StackPanel Margin="4,2,0,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderThickness="0,0,0,4"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <StackPanel x:Name="SourceList" Orientation="Horizontal" Margin="0,0,0,0"/>
                </Border>
                <Grid Grid.Row="1" >
                    <StackPanel x:Name="SourceContents" Orientation="Vertical" MinHeight="100"
                                Margin="12,10,8,6"/>
                </Grid>
            </Grid>
        </StackPanel>
    </Expander>
</settingsViews:SettingsGroupControl>