<views:SettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.External.MakeShipSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:SubathonManager.UI.Views"
             xmlns:validation="clr-namespace:SubathonManager.UI.Validation"
             mc:Ignorable="d">
    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
            <ui:TextBlock Text="Status:" Width="80" VerticalAlignment="Center" FontSize="12"/>
            <ui:TextBlock x:Name="MakeShipStatusText" Text="Disconnected" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>

        <Grid Margin="10,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,4,8,0">
                <ui:TextBox x:Name="SimNameBox" Width="244" Height="34" PlaceholderText="Product Name"
                            Margin="0,0,0,6" FontSize="12"
                            views:SettingsProperties.ExcludeFromUnsaved="True"/>
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="SimTypeBox" Width="120" Height="34" SelectedIndex="0" FontSize="12"
                              views:SettingsProperties.ExcludeFromUnsaved="True">
                        <ComboBoxItem Content="Pledge"/>
                        <ComboBoxItem Content="Campaign"/>
                    </ComboBox>
                    <ui:TextBox x:Name="SimCountBox" Width="52" Height="34" Text="1" Margin="6,0,0,0"
                                ClearButtonEnabled="False" FontSize="12" ToolTip="Quantity"
                                validation:InputValidationBehavior.IsNumberOnly="True"
                                views:SettingsProperties.ExcludeFromUnsaved="True"/>
                    <ui:Button Content="Test" Width="60" Height="34" Padding="2" Margin="6,0,0,0"
                               Click="TestMakeShip_Click"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               views:SettingsProperties.ExcludeFromUnsaved="True"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="0">
            <Grid Margin="0,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Petition Pledges:" Width="120" VerticalAlignment="Center"
                               ToolTip="Value applied per pledge on tracked petitions"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="60" x:Name="PledgeBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds per pledge" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="PledgeBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points per pledge" Width="180" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Grid Margin="0,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Campaign Sales:" Width="120" VerticalAlignment="Center"
                               ToolTip="Value applied per sold item on tracked product campaigns"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="60" x:Name="OrderBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds per sale" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="OrderBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points per sale" Width="180" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            </StackPanel>
        </Grid>

        <Separator Margin="0,8,0,8"/>

        <TextBlock Text="Tracked Petitions and Campaigns" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,6" TextWrapping="Wrap"
                   ToolTip="Petitions must be a valid petition Url. Product pages must be for an active and valid campaign Url - permanent products are invalid."
                   Text="Paste your MakeShip Petition or Product page Url"/>

        <StackPanel x:Name="TrackingsPanel"/>

        <ui:Button x:Name="AddTrackingBtn" Content="Add Url" Width="120" Height="32" Margin="0,6,0,4"
                   Icon="Add24" Click="AddTracking_Click"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   views:SettingsProperties.ExcludeFromUnsaved="True"/>
    </StackPanel>
</views:SettingsControl>
