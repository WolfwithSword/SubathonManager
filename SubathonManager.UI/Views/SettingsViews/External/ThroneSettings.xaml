<local:DevTunnelSettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.External.ThroneSettings"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:SubathonManager.UI.Views.SettingsViews.External"
                        xmlns:views="clr-namespace:SubathonManager.UI.Views"
                        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                        xmlns:validation="clr-namespace:SubathonManager.UI.Validation"
                        mc:Ignorable="d">
    <StackPanel>
<StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
            <ui:TextBlock Text="Status:" Width="80" VerticalAlignment="Center" FontSize="12"/>
            <ui:TextBlock x:Name="ThroneWebhookStatusText" Text="Disconnected" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>

        <!-- DevTunnels prerequisite status -->
        <Border x:Name="TunnelStatusBorder" BorderThickness="1" CornerRadius="4" Padding="8,6"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="DevTunnels:" Width="110" VerticalAlignment="Center" FontSize="12"/>
                    <ui:TextBlock x:Name="TunnelPrereqStatusText" Text="Not running"
                               VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0"/>
                    <ui:Button Content="Go to setup" Click="GoToDevTunnels_Click" x:Name="TunnelPrereqHint" FontSize="11" 
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                </StackPanel>
                <StackPanel x:Name="WebhookUrlRow" Orientation="Horizontal" Margin="0,8,0,2" Visibility="Collapsed"
                            MinHeight="36">
                    <TextBlock Text="Webhook URL:" Width="110" VerticalAlignment="Center" FontSize="12"/>
                    <ui:PasswordBox x:Name="WebhookUrlBox" Width="420" Height="34" IsReadOnly="True"
                                views:SettingsProperties.ExcludeFromUnsaved="True" ClearButtonEnabled="False"
                                FontSize="11" VerticalAlignment="Center"/>
                    <ui:Button Content="Copy"
                               Click="CopyWebhookUrl_Click"
                               Width="56" Height="34" Padding="4,2"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="6,0,2,0"/>
                    
                    <ui:Button Content="Setup Throne" Margin="4 0" Width="112" Height="34" Click="OpenThroneLink_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Configuration -->
        <StackPanel Margin="0,2">
            <StackPanel Orientation="Horizontal" Margin="2,4">
                <ui:Button Content="Connect" Margin="0 0" Width="116" Height="34" Click="ConnectThrone_Click" x:Name="ConnectBtn"/>
                <ui:Button Content="Disconnect" Margin="4 0" Width="116" Height="34" Click="DisconnectThrone_Click" Visibility="Collapsed" x:Name="DisconnBtn"/>
            </StackPanel>
        </StackPanel>
        
        <Separator Margin="0,8,0,8"/>
    </StackPanel>
        <StackPanel Margin="10,5,0,5">

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Contributions:" Width="100" VerticalAlignment="Center"
                               ToolTip="Contributions toward crowd gifts"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="12" x:Name="ContribBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="ContribBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points" Width="80" VerticalAlignment="Center" ToolTip="Rounded down"/>
                    <TextBlock Text="Per Dollar" VerticalAlignment="Center" Width="60" Margin="12 0 2 0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:TextBox Margin="10,0,4,0" Width="80" Text="10.00" PlaceholderText="1.00"
                                HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"
                                ClearButtonEnabled="False" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsDecimalOnly="True"
                                x:Name="SimulateThroneContribAmountBox"/>
                    <ComboBox Width="100" IsEditable="True" IsTextSearchEnabled="True"
                              x:Name="CurrencyBox" StaysOpenOnEdit="True" Height="34"
                              views:SettingsProperties.ExcludeFromUnsaved="True" Margin="4,0,4,0"/>
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestThroneContrib_Click"
                               Width="60" Padding="2" Height="34" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
            
            <Grid Margin="0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Gifts:" Width="100" VerticalAlignment="Center" x:Name="ThroneGiftsText"
                               ToolTip="Gift purchased"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="12" x:Name="GiftsBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="GiftsBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points" Width="80" VerticalAlignment="Center"/>
                    <TextBlock Text="Per " VerticalAlignment="Center" Width="30" Margin="12 0 2 0" ToolTip="Item will be treated as per individual gift purchased."/>
                    <ComboBox Text="Mode" Width="100"
                              x:Name="ModeBox"
                              SelectedIndex="0" Margin="4 0 4 0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 0">
                    <!-- <ui:TextBox Margin="4 0 4 0" Width="80" Text="29.99" -->
                    <!--             PlaceholderText="1.00" HorizontalAlignment="Center" VerticalAlignment="Center" -->
                    <!--             FontSize="12" Height="34" -->
                    <!--             views:SettingsProperties.ExcludeFromUnsaved="True" -->
                    <!--             validation:InputValidationBehavior.IsDecimalOnly="True" -->
                    <!--             ClearButtonEnabled="False" -->
                    <!--             x:Name="GiftsSimBox"/> -->
                    <ui:TextBox Margin="4 0 4 0" Width="188" Text="Fancy Item" ClearButtonEnabled="False"
                                HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="GiftNameBox"
                                views:SettingsProperties.ExcludeFromUnsaved="True"/>
                    <!-- <ComboBox Width="100" IsEditable="True" IsTextSearchEnabled="True" -->
                    <!--           x:Name="OrderCurrencyBox" StaysOpenOnEdit="True" Height="34" -->
                    <!--           views:SettingsProperties.ExcludeFromUnsaved="True" Margin="4,0,4,0"/> -->
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestThroneGift_Click"
                               Width="60" Padding="2" Height="34"
                               views:SettingsProperties.ExcludeFromUnsaved="True"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
            
            <Grid Margin="0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Crowd Funding Completed:" Width="200" VerticalAlignment="Center"
                               ToolTip="A crowdfunding gift is completed, only behaves as an alert"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 0">
                    
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestThroneCrowdfund_Click"
                               Width="60" Padding="2" Height="34"
                               views:SettingsProperties.ExcludeFromUnsaved="True"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </StackPanel>
</local:DevTunnelSettingsControl>
