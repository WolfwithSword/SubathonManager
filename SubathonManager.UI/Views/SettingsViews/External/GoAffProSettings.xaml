<views:SettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.External.GoAffProSettings"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:local="clr-namespace:SubathonManager.UI.Views.SettingsViews"
                       xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                       xmlns:views="clr-namespace:SubathonManager.UI.Views">
    <!-- <Expander Header="GoAffPro" IsExpanded="False"> -->
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Content="Connect"
                           Click="OpenLogin_Click"
                           Padding="2"
                           Width="120"
                           Height="35"
                           x:Name="ConnectBtn"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock x:Name="StatusText" Text="Disconnected" VerticalAlignment="Center" FontSize="12" Margin="14 0 0 0"/>
            </StackPanel>

            <StackPanel Margin="4,2,0,5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderThickness="0,0,0,4"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                        <StackPanel x:Name="SourceList" Orientation="Horizontal" Margin="0,0,0,0"/>
                    </Border>
                    <Grid Grid.Row="1" >
                        <StackPanel x:Name="SourcesPanel" MinHeight="100"
                                    Margin="12,10,8,6"/>
                    </Grid>
                </Grid>
            </StackPanel>
        </StackPanel>
    <!-- </Expander> -->
</views:SettingsControl>