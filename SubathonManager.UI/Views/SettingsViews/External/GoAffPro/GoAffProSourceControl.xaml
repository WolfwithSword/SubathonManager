<views:SettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.External.GoAffPro.GoAffProSourceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:validation="clr-namespace:SubathonManager.UI.Validation"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:SubathonManager.UI.Views"
             mc:Ignorable="d">
    <!-- <Expander x:Name="SourceExpander" IsExpanded="False" Margin="0,5,0,0"> -->
        <StackPanel x:Name="SourcePanel">
            <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                <TextBlock x:Name="StatusText" Text="Disconnected" VerticalAlignment="Center" Width="120" FontSize="12" Margin="0 0 0 0"/>
                <TextBlock x:Name="CurrencyText" Text="" VerticalAlignment="Center" FontSize="12" Width="60" Margin="14 0 0 0"/>
                <CheckBox x:Name="EnabledBox" Content="Enabled" Margin="14 0 0 0"/>
                <CheckBox x:Name="CommissionBox" Content="Add commission amount as donation?" Margin="14 0 0 0"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Orders:" Width="100" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True" PlaceholderText="60"
                                x:Name="SecondsBox"/>
                    <TextBlock Margin="8 0 0 0" Text="Seconds" Width="90" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True" PlaceholderText="1"
                                x:Name="PointsBox"/>
                    <TextBlock Margin="8 0 0 0" Text="Points" Width="70" VerticalAlignment="Center"/>

                    <TextBlock Text="Per: " VerticalAlignment="Center" Width="30" Margin="12 0 2 0"/>
                    <ComboBox Text="Mode" Width="100"
                              x:Name="ModeBox"
                              SelectedIndex="0" Margin="4 0 4 0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:TextBox Margin="10 0 4 0" Width="80" Text="29.99"
                                PlaceholderText="1.00" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsDecimalOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="TotalSimBox"/>
                    <ui:TextBox Margin="10 0 4 0" Width="80" Text="2.99"
                                PlaceholderText="1.00" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsDecimalOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="CommSimBox"/>
                    <ui:TextBox Margin="10 0 4 0" Width="80" Text="1"
                                PlaceholderText="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsNumberOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="QuantitySimBox"/>
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestOrder_Click"
                               Width="60" Padding="2" Height="34"
                               views:SettingsProperties.ExcludeFromUnsaved="True"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    <!-- </Expander> -->
</views:SettingsControl>
