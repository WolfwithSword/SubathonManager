<local:DevTunnelSettingsControl x:Class="SubathonManager.UI.Views.SettingsViews.External.FourthWallSettings"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:SubathonManager.UI.Views.SettingsViews.External"
                        xmlns:views="clr-namespace:SubathonManager.UI.Views"
                        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                        xmlns:validation="clr-namespace:SubathonManager.UI.Validation"
                        mc:Ignorable="d">
    <StackPanel>
<StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
            <ui:TextBlock Text="Status:" Width="80" VerticalAlignment="Center" FontSize="12"/>
            <ui:TextBlock x:Name="FwWebhookStatusText" Text="Disconnected" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>

        <!-- DevTunnels prerequisite status -->
        <Border x:Name="TunnelStatusBorder" BorderThickness="1" CornerRadius="4" Padding="8,6"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="DevTunnels:" Width="110" VerticalAlignment="Center" FontSize="12"/>
                    <ui:TextBlock x:Name="TunnelPrereqStatusText" Text="Not running"
                               VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0"/>
                    <ui:Button Content="Go to setup" Click="GoToDevTunnels_Click" x:Name="TunnelPrereqHint" FontSize="11" 
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                </StackPanel>
                <StackPanel x:Name="WebhookUrlRow" Orientation="Horizontal" Margin="0,8,0,2" Visibility="Collapsed"
                            MinHeight="36">
                    <TextBlock Text="Webhook URL:" Width="110" VerticalAlignment="Center" FontSize="12"/>
                    <ui:PasswordBox x:Name="WebhookUrlBox" Width="420" Height="34" IsReadOnly="True"
                                views:SettingsProperties.ExcludeFromUnsaved="True" ClearButtonEnabled="False"
                                FontSize="11" VerticalAlignment="Center"/>
                    <ui:Button Content="Copy"
                               Click="CopyWebhookUrl_Click"
                               Width="56" Height="34" Padding="4,2"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="6,0,2,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Configuration -->
        <StackPanel Margin="0,2">
            <StackPanel Orientation="Horizontal" Margin="2,4">
                <ui:Button Content="Connect" Margin="0 0" Width="116" Height="34" Click="ConnectFw_Click" x:Name="ConnectBtn"/>
                <ui:Button Content="Disconnect" Margin="4 0" Width="116" Height="34" Click="DisconnectFw_Click" Visibility="Collapsed" x:Name="DisconnBtn"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4,4">
                <TextBlock Text="Forward URL(s):" Width="160" VerticalAlignment="Center"
                           ToolTip="A list of URLs to forward the raw Fourthwall webhook to. Leave blank to disable."/>
                <ui:TextBox x:Name="FwWebhookForwardUrlsBox" Width="360" Height="34" IsReadOnly="True" ClearButtonEnabled="False"
                            PlaceholderText="No URLs configured" MouseDoubleClick="EditForwardUrls_Click"
                            PreviewMouseLeftButtonUp="EditForwardUrls_Click"
                            ToolTip="Click to edit, one URL per line"/>

                <Popup x:Name="ForwardUrlsPopup" StaysOpen="True" Placement="Bottom"
                       PlacementTarget="{Binding ElementName=FwWebhookForwardUrlsBox}"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="10"
                            MinWidth="450">
                        <StackPanel>
                            <TextBlock Text="One URL per line:" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ui:TextBox x:Name="ForwardUrlsMultiBox"
                                     AcceptsReturn="True" TextWrapping="NoWrap"
                                     MinHeight="80" MaxHeight="240" Width="500"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     FontSize="12" Padding="4"
                                     BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                     BorderThickness="1"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <ui:Button Content="Cancel" Width="70" Height="28" Padding="4,2"
                                           Margin="0,0,6,0" Click="ForwardUrlsCancel_Click"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ui:Button Content="Apply" Width="70" Height="28" Padding="4,2"
                                           Click="ForwardUrlsApply_Click"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </StackPanel>
        
        <Separator Margin="0,8,0,8"/>
    </StackPanel>
        <StackPanel Margin="10,5,0,5">

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Donations:" Width="100" VerticalAlignment="Center"
                               ToolTip="Donations (not including donations from orders)"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="12" x:Name="DonoBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds per 1$" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="DonoBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points per 1$, rounded down" Width="180" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:TextBox Margin="10,0,4,0" Width="80" Text="10.00" PlaceholderText="1.00"
                                HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"
                                ClearButtonEnabled="False" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsDecimalOnly="True"
                                x:Name="SimulateFwTipAmountBox"/>
                    <ComboBox Width="100" IsEditable="True" IsTextSearchEnabled="True"
                              x:Name="CurrencyBox" StaysOpenOnEdit="True" Height="34"
                              views:SettingsProperties.ExcludeFromUnsaved="True" Margin="4,0,4,0"/>
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestFwTip_Click"
                               Width="60" Padding="2" Height="34" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
            
            <Grid Margin="0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Orders:" Width="100" VerticalAlignment="Center" x:Name="FwOrdersText"
                               ToolTip="Orders"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="12" x:Name="ShopOrderBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="ShopOrderBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points" Width="80" VerticalAlignment="Center"/>
                    <TextBlock Text="Per: " VerticalAlignment="Center" Width="30" Margin="12 0 2 0"/>
                    <ComboBox Text="Mode" Width="100"
                              x:Name="ModeBox"
                              SelectedIndex="0" Margin="4 0 4 0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 0">
                    <ui:TextBox Margin="10 0 4 0" Width="50" Text="1"
                                PlaceholderText="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34" ToolTip="Number of items in the order to sum the amount"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsNumberOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="OrderQuantitySimBox"/>
                    <ui:TextBox Margin="4 0 4 0" Width="80" Text="29.99"
                                PlaceholderText="1.00" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsDecimalOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="OrderTotalSimBox"/>
                    <ComboBox Width="100" IsEditable="True" IsTextSearchEnabled="True"
                              x:Name="OrderCurrencyBox" StaysOpenOnEdit="True" Height="34"
                              views:SettingsProperties.ExcludeFromUnsaved="True" Margin="4,0,4,0"/>
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestFwShopOrder_Click"
                               Width="60" Padding="2" Height="34"
                               views:SettingsProperties.ExcludeFromUnsaved="True"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
            
            <Grid Margin="0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Gift Orders:" Width="100" VerticalAlignment="Center" x:Name="gFwOrdersText"
                               ToolTip="Gift Purchase Orders"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="12" x:Name="gShopOrderBox"/>
                    <TextBlock Margin="8,0,0,0" Text="Seconds" Width="150" VerticalAlignment="Center"/>
                    <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                PlaceholderText="0" x:Name="gShopOrderBox2"/>
                    <TextBlock Margin="8,0,0,0" Text="Points" Width="80" VerticalAlignment="Center"/>
                    <TextBlock Text="Per: " VerticalAlignment="Center" Width="30" Margin="12 0 2 0"/>
                    <ComboBox Text="Mode" Width="100"
                              x:Name="gModeBox"
                              SelectedIndex="0" Margin="4 0 4 0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 0">
                    <ui:TextBox Margin="10 0 4 0" Width="50" Text="1"
                                PlaceholderText="5" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34" ToolTip="Number of items in the order to sum the amount"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsNumberOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="gOrderQuantitySimBox"/>
                    <ui:TextBox Margin="4 0 4 0" Width="80" Text="29.99"
                                PlaceholderText="1.00" HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="12" Height="34"
                                views:SettingsProperties.ExcludeFromUnsaved="True"
                                validation:InputValidationBehavior.IsDecimalOnly="True"
                                ClearButtonEnabled="False"
                                x:Name="gOrderTotalSimBox"/>
                    <ComboBox Width="100" IsEditable="True" IsTextSearchEnabled="True"
                              x:Name="gOrderCurrencyBox" StaysOpenOnEdit="True" Height="34"
                              views:SettingsProperties.ExcludeFromUnsaved="True" Margin="4,0,4,0"/>
                    <ui:Button Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Content="Test" Click="TestFwShopGiftOrder_Click"
                               Width="60" Padding="2" Height="34"
                               views:SettingsProperties.ExcludeFromUnsaved="True"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
            <Grid Margin="0 2 0 0 ">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <CheckBox x:Name="OrderCommissionBox" Content="Add order profit as donation?" Margin="-10 0 0 0"/>
                    <CheckBox x:Name="GiftCommissionBox" Content="Add gift order profit as donation?" Margin="14 0 0 0"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Memberships -->
        <Expander Header="Memberships" IsExpanded="False" Margin="0,5,0,0">
            <StackPanel x:Name="MembershipsPanel" Margin="10,5,0,5">
                <Grid x:Name="DefaultMember" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="4,2">
                        <TextBlock Text="Default:" Width="160" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                    PlaceholderText="60" x:Name="FwSubDTextBox" Height="36"/>
                        <TextBlock Margin="8,0,0,0" Text="Seconds" Width="120" VerticalAlignment="Center"/>
                        <ui:TextBox Width="100" validation:InputValidationBehavior.IsDecimalOnly="True"
                                    Height="36" PlaceholderText="1" x:Name="FwSubDTextBox2"/>
                        <TextBlock Margin="8,0,0,0" Text="Points" Width="100" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- <ui:Button Icon="Add24" Foreground="{DynamicResource TextFillColorPrimaryBrush}" -->
                        <!--            Height="36" Content="Add Membership Tier" x:Name="AddBtn" -->
                        <!--            Click="AddMembership_Click" Width="160" Margin="4,5,4,5"/> -->
                        <ComboBox Text="Duration" Width="110" Height="36" FontSize="12"
                                  x:Name="SimMembershipDuration" ToolTip="Select Monthly (x1) or Annual (x12)"
                                  views:SettingsProperties.ExcludeFromUnsaved="True"
                                  SelectedIndex="0" Margin="4,0,4,0">
                            <ComboBoxItem Content="Monthly"/>
                            <ComboBoxItem Content="Annual"/>
                        </ComboBox>
                        <ComboBox Text="Tier" Width="150" Height="36" FontSize="12"
                                  x:Name="SimFwTierSelection" ToolTip="Select Membership Tier"
                                  views:SettingsProperties.ExcludeFromUnsaved="True"
                                  SelectedIndex="0" Margin="4,0,4,0">
                            <ComboBoxItem Content="DEFAULT"/>
                        </ComboBox>
                        <ui:Button Icon="Add24" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Content="Test" Click="TestFwSub_Click"
                                   Width="60" Padding="2" Height="36" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Expander>

    </StackPanel>
</local:DevTunnelSettingsControl>
