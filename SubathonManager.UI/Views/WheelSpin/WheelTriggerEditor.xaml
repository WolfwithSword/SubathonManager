<UserControl x:Class="SubathonManager.UI.Views.WheelSpin.WheelTriggerEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid MouseDown="Grid_MouseDown" Focusable="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Left Top: triggers list -->
        <Border Grid.Column="0" Grid.Row="0" Padding="8" Margin="16 16 8 -72"
                BorderThickness="1" BorderBrush="#333" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0 0 0 6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Triggers" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ui:Button Grid.Column="1" Width="30" Height="30" Padding="2"
                               ToolTip="Add new trigger" Click="AddTrigger_Click">
                        <ui:SymbolIcon Symbol="Add24" Width="16" Height="16"/>
                    </ui:Button>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 6">
                    <ui:Button Click="ExportTriggers_Click" Height="28" Padding="12 2" Margin="0 0 6 0"
                               ToolTip="Export all triggers to CSV">
                                    <ui:SymbolIcon Symbol="ArrowExportUp24"/></ui:Button>
                    <ui:Button Click="ImportTriggers_Click" Height="28" Padding="12 2"
                               ToolTip="Import triggers from CSV (replaces all existing triggers and history)">
                        <ui:SymbolIcon Symbol="ArrowDownload24"/></ui:Button>
                </StackPanel>

                <Border Grid.Row="2" BorderBrush="#444" BorderThickness="0 0 0 1" Margin="0 0 4 2">
                    <Grid Margin="4 0 4 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="On" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Event" FontSize="11" Foreground="Gray" Margin="4 0 0 0"/>
                        <TextBlock Grid.Column="2" Text="Condition" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Spins" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TriggersStack" Orientation="Vertical" Margin="0 2 0 0"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Left Bottom: trigger history -->
        <Border Grid.Column="0" Grid.Row="1" Padding="8" Margin="16 80 8 16"
                BorderThickness="1" BorderBrush="#333" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0 0 0 4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Trigger History" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ui:Button Grid.Column="1" Width="30" Height="30" Padding="2"
                               ToolTip="Export history to CSV" Click="ExportHistoryToCsv_Click">
                        <ui:SymbolIcon Symbol="ArrowExportUp24" Width="16" Height="16"/>
                    </ui:Button>
                    <ui:Button Grid.Column="2" Width="30" Height="30" Padding="2" Margin="4 0 0 0"
                               ToolTip="Delete all trigger history" Click="DeleteAllTriggerHistory_Click"
                               Foreground="Red">
                        <ui:SymbolIcon Symbol="Delete24" Width="16" Height="16"/>
                    </ui:Button>
                </Grid>

                <Border Grid.Row="1" BorderBrush="#444" BorderThickness="0 0 0 1" Margin="0 0 4 2">
                    <Grid Margin="2 0 2 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="225"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Time" FontSize="10" Foreground="Gray"/>
                        <TextBlock Grid.Column="1" Text="Trigger Event" FontSize="10" Foreground="Gray" Margin="4 0 0 0"/>
                        <TextBlock Grid.Column="2" Text="User" FontSize="10" Foreground="Gray" Margin="4 0 0 0"/>
                        <TextBlock Grid.Column="3" Text="Spins" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" x:Name="TriggerHistoryScroller" VerticalScrollBarVisibility="Auto"
                              ScrollChanged="TriggerHistoryScroller_ScrollChanged">
                    <StackPanel x:Name="TriggerHistoryStack" Orientation="Vertical" Margin="0 2 0 0"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right: trigger editor panel -->
        <Grid Grid.Column="1" Grid.Row="0" Grid.RowSpan="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20 16 16 56">
                    <TextBlock x:Name="EditorTitle" Text="Trigger Editor" FontSize="20" FontWeight="Bold" Margin="0 0 0 12"/>
                    <Border x:Name="TriggerDetailBorder" Visibility="Collapsed">
                        <StackPanel>

                            <CheckBox x:Name="TriggerEnabledCheck" Content="Enabled" FontSize="13"
                                      Margin="0 0 0 14"/>

                            <Grid Margin="2 0 0 3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Event Type:" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="EventTypeSourceLabel" Grid.Column="1" FontSize="11"
                                           Foreground="CornflowerBlue" VerticalAlignment="Center"/>
                            </Grid>
                            <Button x:Name="EventTypePickerBtn"
                                    Height="36"
                                    Margin="0 0 0 12"
                                    MinWidth="230"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="8 0 6 0"
                                    Click="EventTypePickerBtn_Click"
                                    Background="{DynamicResource ComboBoxBackground}"
                                    BorderBrush="{DynamicResource ComboBoxBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="EventTypePickerLabel"
                                               Text="- select -"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                            <Border x:Name="TierPanel" Visibility="Collapsed"
                                    Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                                    Margin="0 0 0 10">
                                <StackPanel>
                                    <TextBlock Text="Tier" FontSize="13" FontWeight="SemiBold" Margin="0 0 0 6"/>

                                    <StackPanel x:Name="TierComboPanel" Visibility="Collapsed">
                                        <TextBlock Text="Tier:" FontSize="12" Margin="2 0 0 3"/>
                                        <ComboBox x:Name="TierComboBox" Height="36"/>
                                    </StackPanel>

                                    <StackPanel x:Name="TierTextPanel" Visibility="Collapsed">
                                        <TextBlock Text="Tier Name:" FontSize="12" Margin="2 0 0 3"/>
                                        <ui:TextBox x:Name="TierTextBox" Height="36" ClearButtonEnabled="False"
                                                    PlaceholderText="e.g. DEFAULT, Bronze, Basic Member..."
                                                    ToolTip="Enter the tier name as it appears from the platform. Use DEFAULT for platforms with a single membership tier."/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="GiftCountPanel" Visibility="Collapsed"
                                    Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                                    Margin="0 0 0 10">
                                <StackPanel>
                                    <TextBlock Text="Gift Count" FontSize="13" FontWeight="SemiBold" Margin="0 0 0 6"/>
                                    <TextBlock Text="Gifts Required:" FontSize="12" Margin="2 0 0 3"/>
                                    <ui:TextBox x:Name="GiftCountBox" Height="36" ClearButtonEnabled="False"
                                                PlaceholderText="e.g. 10"
                                                PreviewTextInput="NumberOnly_PreviewTextInput"
                                                ToolTip="How many gifts must arrive to add the configured spins. Remainder is discarded - e.g. threshold 10: 25 gifts -> 2x, 49 gifts -> 4x."/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TokenCountPanel" Visibility="Collapsed"
                                    Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                                    Margin="0 0 0 10">
                                <StackPanel>
                                    <TextBlock Text="Token Count" FontSize="13" FontWeight="SemiBold" Margin="0 0 0 6"/>
                                    <TextBlock Text="Tokens Required:" FontSize="12" Margin="2 0 0 3"/>
                                    <ui:TextBox x:Name="TokenCountBox" Height="36" ClearButtonEnabled="False"
                                                PlaceholderText="e.g. 500"
                                                PreviewTextInput="NumberOnly_PreviewTextInput"
                                                ToolTip="How many tokens (bits, beets, etc.) per spin batch. Remainder is discarded."/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="OrderModePanel" Visibility="Collapsed"
                                    Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                                    Margin="0 0 0 10">
                                <StackPanel>
                                    <TextBlock Text="Order Trigger" FontSize="13" FontWeight="SemiBold" Margin="0 0 0 8"/>

                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                        <RadioButton x:Name="OrderByItemsRadio" Content="By Item Count"
                                                     GroupName="OrderMode" IsChecked="True"
                                                     Checked="OrderMode_Changed" Margin="0 0 20 0"/>
                                        <RadioButton x:Name="OrderByMoneyRadio" Content="By Money Spent"
                                                     GroupName="OrderMode"
                                                     Checked="OrderMode_Changed" Margin="0 0 20 0"/>
                                        <RadioButton x:Name="OrderByOrderRadio" Content="Per Order"
                                                     GroupName="OrderMode"
                                                     Checked="OrderMode_Changed"/>
                                    </StackPanel>

                                    <StackPanel x:Name="OrderItemPanel">
                                        <TextBlock Text="Items Required:" FontSize="12" Margin="2 0 0 3"/>
                                        <ui:TextBox x:Name="OrderItemCountBox" Height="36" ClearButtonEnabled="False"
                                                    PlaceholderText="e.g. 3"
                                                    PreviewTextInput="NumberOnly_PreviewTextInput"
                                                    ToolTip="Number of items per spin batch. Remainder is discarded."/>
                                    </StackPanel>

                                    <StackPanel x:Name="OrderMoneyPanel" Visibility="Collapsed">
                                        <Grid Margin="0 0 0 0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Amount ≥:" FontSize="12" Margin="2 0 0 3"/>
                                                <ui:TextBox x:Name="OrderMoneyBox" Height="36" ClearButtonEnabled="False"
                                                            PlaceholderText="e.g. 10.00"
                                                            PreviewTextInput="FloatOnly_PreviewTextInput"
                                                            ToolTip="Spend threshold per spin batch, in the currency below. Remainder is discarded."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Currency:" FontSize="12" Margin="2 0 0 3"/>
                                                <ComboBox x:Name="OrderCurrencyBox" Height="36"
                                                          IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                                          ToolTip="ISO 4217 currency code. Incoming order value is converted to this currency before comparing."/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="DonationPanel" Visibility="Collapsed"
                                    Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                                    Margin="0 0 0 10">
                                <StackPanel>
                                    <TextBlock Text="Donation Threshold" FontSize="13" FontWeight="SemiBold" Margin="0 0 0 6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Amount ≥:" FontSize="12" Margin="2 0 0 3"/>
                                            <ui:TextBox x:Name="DonationMoneyBox" Height="36" ClearButtonEnabled="False"
                                                        PlaceholderText="e.g. 5.00"
                                                        PreviewTextInput="FloatOnly_PreviewTextInput"
                                                        ToolTip="Donation threshold per spin batch, in the currency below. Remainder is discarded."/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Currency:" FontSize="12" Margin="2 0 0 3"/>
                                            <ComboBox x:Name="DonationCurrencyBox" Height="36"
                                                      IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                                      ToolTip="ISO 4217 currency code. Incoming donation is converted to this currency before comparing."/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="10" BorderThickness="1" BorderBrush="#333" CornerRadius="6"
                                    Margin="0 0 0 10">
                                <StackPanel>
                                    <TextBlock Text="Spins to Add" FontSize="13" FontWeight="SemiBold" Margin="0 0 0 6"/>
                                    <TextBlock Text="Spins:" FontSize="12" Margin="2 0 0 3"/>
                                    <ui:TextBox x:Name="SpinsToAddBox" Height="36" Width="100"
                                                HorizontalAlignment="Left"
                                                ClearButtonEnabled="False"
                                                PlaceholderText="e.g. 5"
                                                PreviewTextInput="NumberOnly_PreviewTextInput"
                                                ToolTip="Number of spins added per qualifying batch (multiplied by how many batches qualify)."/>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="TriggerStatusText" Foreground="OrangeRed" FontSize="11"
                                       TextWrapping="Wrap" Margin="0 4 0 0"/>

                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="TriggerPlaceholderText"
                               Text="Select a trigger from the list or add a new one."
                               FontSize="12" Foreground="Gray" TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>

            <Border x:Name="SaveButtonBorder" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    CornerRadius="6" BorderThickness="2" BorderBrush="Transparent"
                    Margin="6 10 14 10">
                <ui:Button x:Name="SaveTriggerBtn" Content="Save Changes"
                           Click="SaveTrigger_Click" Width="140" Height="38"
                           IsEnabled="False"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
